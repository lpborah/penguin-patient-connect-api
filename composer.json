    "phpmailer/phpmailer": "~6.5.0",
    "psr/container": "1.0.0",
    "psr/http-message": "^1.0",
    "psr/log": "^1.1",
    "monolog/monolog": "^2.10"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
